# YouTube Clipper 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================================================
# FFmpeg 配置
# ============================================================================

# FFmpeg 可执行文件路径（可选，留空则自动检测）
# macOS (Apple Silicon): /opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
# macOS (Intel): /usr/local/opt/ffmpeg-full/bin/ffmpeg
# Linux: /usr/bin/ffmpeg
FFMPEG_PATH=

# 字幕烧录样式
SUBTITLE_FONT_SIZE=24
SUBTITLE_MARGIN_V=30

# ============================================================================
# 输出配置
# ============================================================================

# 输出目录（默认: 当前工作目录下的 youtube-clips/）
OUTPUT_DIR=./youtube-clips

# 视频质量限制（最高分辨率）
# 选项: 720, 1080, 1440, 2160 (4K)
MAX_VIDEO_HEIGHT=1080

# ============================================================================
# 字幕翻译配置（旧版 Skill 编排）
# ============================================================================

# 批量翻译大小由下方 V2 配置块中的 TRANSLATION_BATCH_SIZE 统一定义

# 目标翻译语言
# 选项: 中文, 日语, 韩语, 西班牙语, 等
TARGET_LANGUAGE=中文

# ============================================================================
# 字幕翻译 V2 配置（Translation V2 / OpenAI-compatible）
# ============================================================================

# 必填：OpenAI-compatible provider 基础配置
TRANSLATION_PROVIDER=openai-compatible
TRANSLATION_BASE_URL=http://127.0.0.1:8317/v1
TRANSLATION_API_KEY=
TRANSLATION_MODEL=deepseek-chat
TRANSLATION_TARGET_LANG=zh-CN

# 推荐：显式设置 v2 + 非 structured 输出。注意：如果省略该变量，代码默认仍是 v1
TRANSLATION_ENGINE_VERSION=v2
TRANSLATION_STRUCTURED_OUTPUT=false
TRANSLATION_MODE=balanced
TRANSLATION_TEMPERATURE=0.1
TRANSLATION_MAX_RETRIES=3
TRANSLATION_FAILURE_MODE=strict

# 可选：模型与路由
# 留空时，TRANSLATION_REVIEW_MODEL 会回落到 TRANSLATION_MODEL
TRANSLATION_REVIEW_MODEL=
# 留空表示不启用 fallback model
TRANSLATION_FALLBACK_MODEL=
TRANSLATION_MAIN_MODEL_ALIAS=main
TRANSLATION_REPAIR_MODEL_ALIAS=repair
TRANSLATION_FALLBACK_MODEL_ALIAS=fallback

# 批处理与上下文
TRANSLATION_BATCH_SIZE=80
TRANSLATION_BATCH_MAX_CHARS=
TRANSLATION_BATCH_MAX_CUES=
TRANSLATION_CONTEXT_BEFORE=10
TRANSLATION_CONTEXT_AFTER=10

# Auto-sub preprocessing（Cycle 2，默认关闭）
# 推荐仅用于 YouTube auto-generated subtitles。手动字幕通常保持关闭。
# single_file 是 degraded fallback；full_vtt_window 是推荐模式。
# clip_start/end 使用原视频绝对时间毫秒；padding 仅用于 segmentation context。
TRANSLATION_PREPROCESS_AUTO_SUBS=false
TRANSLATION_AUTO_SUB_SOURCE_MODE=single_file
TRANSLATION_AUTO_SUB_FULL_VTT_PATH=
TRANSLATION_AUTO_SUB_CLIP_START_MS=
TRANSLATION_AUTO_SUB_CLIP_END_MS=
TRANSLATION_AUTO_SUB_PADDING_BEFORE_MS=10000
TRANSLATION_AUTO_SUB_PADDING_AFTER_MS=10000
TRANSLATION_SEGMENT_MAX_UNIT_CHARS=180
TRANSLATION_SEGMENT_MAX_UNIT_DURATION_MS=7000
TRANSLATION_SEGMENT_MAX_SOURCE_CUES=5
TRANSLATION_SEGMENT_MAX_SENTENCES=2

# 缓存 / QA / glossary
TRANSLATION_CACHE=true
TRANSLATION_CACHE_PATH=.translation_cache.sqlite3
TRANSLATION_GLOSSARY_PATH=glossary.md
TRANSLATION_QA=suspicious-only

# 并发与自适应并发（Phase 8）
# TRANSLATION_CONCURRENCY 是硬上限
TRANSLATION_CONCURRENCY=1
TRANSLATION_ADAPTIVE_CONCURRENCY_ENABLED=false
TRANSLATION_ADAPTIVE_CONCURRENCY_MIN=1
# 留空时表示使用 TRANSLATION_CONCURRENCY 作为 adaptive max
TRANSLATION_ADAPTIVE_CONCURRENCY_MAX=

# 报告 / batching 元数据版本
TRANSLATION_OUTPUT_SCHEMA_VERSION=v1
TRANSLATION_BATCHING_STRATEGY_VERSION=v1

# ============================================================================
# 章节分析配置
# ============================================================================

# 目标章节时长（秒）
# 推荐: 180 (3分钟) - 300 (5分钟)
TARGET_CHAPTER_DURATION=180

# ============================================================================
# yt-dlp 配置
# ============================================================================

# yt-dlp 浏览器 cookies 来源（受限视频/高质量下载推荐）
# 例如: firefox 或 firefox:default-release
YT_DLP_COOKIES_FROM_BROWSER=

# yt-dlp cookies 文件路径（Netscape cookies.txt 格式）
YT_DLP_COOKIES_FILE=

# yt-dlp 代理设置（如果需要）
# 格式: http://proxy-server:port 或 socks5://proxy-server:port
YT_DLP_PROXY=

# yt-dlp 下载速率限制（如果需要）
# 格式: 50K, 4.2M, 等
YT_DLP_RATE_LIMIT=

# 可选：启用 yt-dlp impersonation（用于某些高质量 DASH 下载更稳定）
# 示例: chrome:windows-10
# 留空则不启用
YTDLP_IMPERSONATE=

# ============================================================================
# 高级配置
# ============================================================================

# 临时文件目录（用于解决路径空格问题）
# 留空则使用系统默认临时目录
TEMP_DIR=

# 是否保留临时文件（调试用）
# 选项: true, false
KEEP_TEMP_FILES=false

# 日志级别
# 选项: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# 注意事项
# ============================================================================

# 1. 此文件中的配置是可选的，如果不设置，Skill 会使用默认值
# 2. 路径可以使用 ~ 表示用户主目录
# 3. 环境变量值不需要引号
# 4. 以 # 开头的行是注释
# 5. 配置会在脚本运行时自动加载，修改后下次运行即生效
